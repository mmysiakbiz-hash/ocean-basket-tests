{
  "name": "ocean-basket-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Automated Playwright tests for the Ocean Basket Seychelles app + admin.",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report",
    "test:live": "playwright test --config=playwright.live.config.js",
    "report:live": "playwright show-report playwright-report-live"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0"
  }
}